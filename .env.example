# ─── Railway — variáveis obrigatórias ────────────────────────────────────────

# PostgreSQL (adicione o plugin PostgreSQL no Railway e use a URL gerada)
DATABASE_URL=postgresql://user:password@host:5432/anvisa

# Segredo para cookies de sessão (gere com: openssl rand -hex 32)
JWT_SECRET=change-me-to-a-random-secret

# ─── Backblaze B2 (para downloads reais) ───────────────────────────────────

B2_APPLICATION_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET_NAME=discorailway
# Região S3 do bucket B2 — opcional; stats de armazenamento usam API nativa B2 (não precisa desta var)
# B2_S3_REGION=us-west-004

# ─── Catálogo ANVISA (inventário completo) ───────────────────────────────────
ANVISA_CATALOG_SCRIPT_PATH=/app/scripts/anvisa_catalog_sync.py
# Fonte: CSV oficial (a API Guest não pagina corretamente)
ANVISA_CATALOG_QUERY=open_data
ANVISA_CATALOG_PAGE_SIZE=50
# Pausa entre páginas (segundos)
ANVISA_CATALOG_DELAY=0.2
# Limite opcional de páginas por execução (vazio = catálogo inteiro)
# ANVISA_CATALOG_MAX_PAGES=100

MAX_FILES=10000
ANVISA_AUTO_RUN=true
MAX_WORKERS=4
LOG_LEVEL=INFO
ANVISA_SCRIPT_PATH=/app/scripts/anvisa_downloader_b2.py

# ─── Busca de manuais ────────────────────────────────────────────────────────
# Modo de busca:
#   open_data (padrão) — CSV oficial dados.anvisa.gov.br + API de detalhe por processo
#   terms — legado via API (Guest ignora busca/paginação; não recomendado)
ANVISA_SCAN_MODE=open_data
ANVISA_OPEN_DATA_URL=https://dados.anvisa.gov.br/dados/TA_PRODUTO_SAUDE_SITE.csv
ANVISA_OPEN_DATA_CACHE=/tmp/ta_produto_saude_site.csv
ANVISA_OPEN_DATA_CACHE_HOURS=24
# Por padrão desliga verificação SSL (certificado de dados.anvisa.gov.br falha em containers)
ANVISA_OPEN_DATA_VERIFY_SSL=false
# Limite opcional de linhas do CSV por execução (0 = arquivo inteiro)
# ANVISA_OPEN_DATA_MAX_ROWS=5000
# Total estimado de produtos no catálogo ANVISA (para barra de progresso na UI)
ANVISA_CATALOG_TOTAL=188764

# Filtro de equipamentos médicos (palavras-chave no nome comercial ou técnico)
ANVISA_EQUIPMENT_KEYWORDS=ventilador,monitor,oximetro,bomba infusao,desfibrilador,eletrocardiografo,ultrassom,tomografo,endoscopio,marcapasso,autoclave,esterilizador,incubadora,hemodialise

# Legado — só usado se ANVISA_SCAN_MODE=terms (ou como fallback de keywords)
# REMOVA esta variável no Railway se ainda tiver termos antigos (cateter, seringa, etc.)
# ANVISA_SEARCH_TERMS=ventilador,monitor,oximetro

ANVISA_PAGE_SIZE=50
ANVISA_MAX_PAGES=500
ANVISA_MAX_EMPTY_PAGES=20
ANVISA_DETAIL_DELAY=0.15
ANVISA_MIN_PDF_BYTES=20480
# Por padrão baixa todos os PDFs do produto (manual, rotulagem, etc.)
ANVISA_ANY_PDF=true
# Se true, restringe só a anexos de instruções de uso / manual
ANVISA_MANUAL_ONLY=false

# ─── OAuth Manus (opcional — dashboard funciona sem login) ───────────────────

VITE_APP_ID=
OAUTH_SERVER_URL=
VITE_OAUTH_PORTAL_URL=
OWNER_OPEN_ID=
OWNER_NAME=

# ─── Railway (injetado automaticamente) ──────────────────────────────────────

# PORT=3000
# RAILWAY_ENVIRONMENT=production
