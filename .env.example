# ─── Railway — variáveis obrigatórias ────────────────────────────────────────

# PostgreSQL (adicione o plugin PostgreSQL no Railway e use a URL gerada)
DATABASE_URL=postgresql://user:password@host:5432/anvisa

# Segredo para cookies de sessão (gere com: openssl rand -hex 32)
JWT_SECRET=change-me-to-a-random-secret

# ─── Backblaze B2 (para downloads reais) ───────────────────────────────────

B2_APPLICATION_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET_NAME=anvisa-manuais

# ─── Downloader Python ───────────────────────────────────────────────────────

MAX_FILES=100
MAX_WORKERS=4
LOG_LEVEL=INFO
ANVISA_SCRIPT_PATH=/app/scripts/anvisa_downloader_b2.py
# Termos de busca separados por vírgula (API ANVISA)
ANVISA_SEARCH_TERMS=cateter,bomba,monitor,seringa,ventilador
ANVISA_PAGE_SIZE=20
# Máx. páginas por termo de busca (evita varrer catálogo inteiro)
ANVISA_MAX_PAGES=25
# Para após N páginas seguidas sem nenhum manual
ANVISA_MAX_EMPTY_PAGES=8
# Pausa entre consultas de detalhe (segundos) — reduz erro 503
ANVISA_DETAIL_DELAY=0.15
# Tamanho mínimo do PDF em bytes (rejeita arquivos truncados/corrompidos)
ANVISA_MIN_PDF_BYTES=20480
# Se true, baixa qualquer PDF; padrão: só "INSTRUÇÕES DE USO / MANUAL"
ANVISA_ANY_PDF=false

# ─── OAuth Manus (opcional — dashboard funciona sem login) ───────────────────

VITE_APP_ID=
OAUTH_SERVER_URL=
VITE_OAUTH_PORTAL_URL=
OWNER_OPEN_ID=
OWNER_NAME=

# ─── Railway (injetado automaticamente) ──────────────────────────────────────

# PORT=3000
# RAILWAY_ENVIRONMENT=production
