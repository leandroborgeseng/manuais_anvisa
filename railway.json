{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "dockerfile",
    "dockerfilePath": "Dockerfile",
    "watchPatterns": [
      "Dockerfile",
      "railway.json",
      "requirements.txt",
      "anvisa_*.py",
      "scripts/**",
      "dashboard/**"
    ]
  },
  "deploy": {
    "numReplicas": 1,
    "healthcheckPath": "/health",
    "healthcheckTimeout": 60,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}
