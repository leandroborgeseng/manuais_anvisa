{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "dockerfile"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "NEVER",
    "restartPolicyMaxRetries": 1
  },
  "env": {
    "PYTHONUNBUFFERED": "1",
    "OUTPUT_DIR": "/app/downloads",
    "LOG_DIR": "/app/logs",
    "MAX_FILES": "100",
    "S3_ENDPOINT": "",
    "S3_BUCKET": "",
    "S3_ACCESS_KEY": "",
    "S3_SECRET_KEY": "",
    "S3_REGION": "us-east-1"
  }
}
